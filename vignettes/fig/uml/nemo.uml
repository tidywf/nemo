@startuml

class Config {
+tool
+pkg
+config
+raw_schemas_all
+initialize(tool,\n  pkg)
+print(...)
+read()
+get_patterns()
+get_ftypes()
+get_ftype(x)
+get_descriptions()
+get_schemas_all(raw_or_tidy)
+get_schema(x,\n  v,\n  raw_or_tidy)
+are_schemas_valid()
+get_col_map(x,\n  v)
+clone(deep)
}

class Tool {
-is_tidied
-is_written
+name
+pkg
+path
+config
+files
+tbls
+raw_schemas_all
+tidy_schemas_all
+get_tidy_schema
+get_raw_schema
+get_col_map
+files_tbl
+initialize(name,\n  pkg,\n  path,\n  files_tbl)
+print(...)
+filter_files(include,\n  exclude)
+list_files(type)
+.dispatch_parse(x,\n  tname)
+.dispatch_tidy(x,\n  tname)
+.parse_by_ftype(x,\n  tname)
+.parse_file(x,\n  name,\n  delim,\n  ...)
+.tidy_file(x,\n  name,\n  convert_types)
+.parse_file_keyvalue(x,\n  name,\n  delim,\n  ...)
+.parse_file_nohead(x,\n  pname,\n  delim,\n  ...)
+tidy(tidy,\n  keep_raw)
+write(diro,\n  format,\n  input_id,\n  output_id,\n  dbconn)
+nemofy(diro,\n  format,\n  input_id,\n  output_id,\n  dbconn,\n  include,\n  exclude)
+clone(deep)
}

class Tool1 {
+initialize(path,\n  files_tbl)
+tidy_table3(x)
+parse_table5(x)
+tidy_table5(x)
+clone(deep)
}

class Workflow {
-is_tidied
-is_written
+name
+path
+tools
+files_tbl
+written_files
-validate_tools(x)
+initialize(name,\n  path,\n  tools)
+print(...)
+filter_files(include,\n  exclude)
+list_files(type)
+tidy(tidy,\n  keep_raw)
+write(diro,\n  format,\n  input_id,\n  output_id,\n  dbconn)
+nemofy(diro,\n  format,\n  input_id,\n  output_id,\n  dbconn,\n  include,\n  exclude)
+get_raw_schemas_all()
+get_tidy_schemas_all()
+get_tbls()
+get_metadata(input_id,\n  output_id,\n  output_dir,\n  pkgs)
+clone(deep)
}

class Workflow1 {
+initialize(path)
+clone(deep)
}
Tool1 <|-- Tool
Workflow1 <|-- Workflow
@enduml
